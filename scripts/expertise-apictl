#!/usr/bin/env bash
#
# expertise-apictl — daily-use service control wrapper for agent-expertise-api.
#
# Hides per-OS service-manager differences (systemctl --user, launchctl,
# sc.exe via WSL interop). Installed by scripts/install.sh; symlink it into
# your PATH manually if you want a global command.
#
# Usage:
#   expertise-apictl start|stop|restart|status
#   expertise-apictl logs [-f] [-n LINES]
#   expertise-apictl health
#   expertise-apictl backup-init [--install-deps]
#   expertise-apictl backup [--output DIR] [--instance-id ID]
#   expertise-apictl restore ARTIFACT [--force-draft] [--i-accept-unsigned-backup]
#   expertise-apictl --help
#
# backup-init bootstraps the signed+encrypted backup surface (ADR-012):
# installs cosign/age/jq when missing (--install-deps), generates the cosign
# keypair and age identity under ~/.config/expertise-api/backup/, and writes
# backup.env. backup/restore orchestrate the ExpertiseApi backup/restore CLI
# verbs plus tar/gzip/age/cosign; see docs/operations/backup-restore-runbook.md.
#

set -euo pipefail

SERVICE="${EXPERTISE_API_SERVICE:-expertise-api}"
LABEL="${EXPERTISE_API_LABEL:-com.thesemicolon.expertise-api}"
HEALTH_URL="${EXPERTISE_API_URL:-http://127.0.0.1:8080}/health"
READY_URL="${EXPERTISE_API_URL:-http://127.0.0.1:8080}/health/ready"
READY_TIMEOUT="${EXPERTISE_API_READY_TIMEOUT:-30}"

log() { printf '[expertise-apictl] %s\n' "$1"; }
err() { printf '[expertise-apictl] ERROR: %s\n' "$1" >&2; exit 1; }

usage() { sed -n '2,23p' "$0" | sed 's/^# \{0,1\}//'; }

detect_os() {
  case "$(uname -s)" in
    Darwin) echo macos ;;
    Linux)
      if grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null && command -v sc.exe >/dev/null 2>&1; then
        echo wsl_to_windows
      else
        echo linux
      fi ;;
    *) err "unsupported OS: $(uname -s) — use expertise-apictl.ps1 on Windows" ;;
  esac
}

OS="$(detect_os)"

# ---------------------------------------------------------------------------
# Detect install scope from install.env. When scope=system on macOS the
# LaunchDaemon runs under launchd's system domain, which requires root for
# lifecycle operations. apictl does not support this transparently (it would
# need sudo + a different launchctl domain). Fail clearly so the operator
# knows to use the system launchctl commands directly.
# ---------------------------------------------------------------------------
_detect_install_scope() {
  local xdg_config install_env recorded
  xdg_config="${XDG_CONFIG_HOME:-${HOME}/.config}"
  install_env="${xdg_config}/expertise-api/install.env"
  if [[ -f "${install_env}" ]]; then
    recorded=$(grep -m1 '^EXPERTISE_API_SCOPE=' "${install_env}" \
               | sed 's/^EXPERTISE_API_SCOPE=//' 2>/dev/null || true)
    printf '%s' "${recorded}"
  else
    printf 'user'
  fi
}

# The system-scope guard applies to service-LIFECYCLE subcommands only —
# backup-init/backup/restore talk to the database and filesystem, never to
# launchd, so they work fine against a --system install.
case "${1:-}" in
  backup-init|backup|restore) _lifecycle_cmd=0 ;;
  *)                          _lifecycle_cmd=1 ;;
esac

if [[ "${OS}" == "macos" && "${_lifecycle_cmd}" == "1" ]]; then
  _recorded_scope="$(_detect_install_scope)"
  if [[ "${_recorded_scope}" == "system" ]]; then
    cat >&2 <<'SYSTEM_SCOPE_MSG'
[expertise-apictl] ERROR: this install was configured with --system (LaunchDaemon).
Full apictl support for the system domain is a planned follow-up.
Use the equivalent system-domain launchctl commands directly (requires sudo):

  sudo launchctl print   system/com.thesemicolon.expertise-api
  sudo launchctl kickstart -k system/com.thesemicolon.expertise-api   # restart
  sudo launchctl bootout system/com.thesemicolon.expertise-api        # stop
  sudo launchctl bootstrap system /Library/LaunchDaemons/com.thesemicolon.expertise-api.plist  # start
SYSTEM_SCOPE_MSG
    exit 2
  fi
fi

# ---------------------------------------------------------------------------
# resolve_log_dir — determine the log directory for the current install.
#
# Precedence (highest to lowest):
#   1. EXPERTISE_API_LOG_DIR env var (explicit override, cheapest escape hatch)
#   2. ${XDG_CONFIG_HOME:-${HOME}/.config}/expertise-api/install.env written
#      by install.sh at install time (recorded-at-install; correct for
#      --prefix installs where log dir diverges from the OS default path)
#   3. OS-default path (backward-compat fallback for pre-existing installs
#      that predate the install.env file)
#
# The install.env file is written to a stable, non-prefix-dependent XDG
# config location so apictl can probe it without knowing which --prefix was
# used at install time. It contains plain key=value lines (no quoting, no
# subshells). We read it with grep+sed — never `source` — so we do not
# execute arbitrary shell from disk.
# ---------------------------------------------------------------------------
resolve_log_dir() {
  # Layer 1: explicit env override
  if [[ -n "${EXPERTISE_API_LOG_DIR:-}" ]]; then
    printf '%s' "${EXPERTISE_API_LOG_DIR}"
    return 0
  fi

  # Layer 2: recorded-at-install value from the stable XDG config location.
  local xdg_config install_env recorded
  xdg_config="${XDG_CONFIG_HOME:-${HOME}/.config}"
  install_env="${xdg_config}/expertise-api/install.env"
  if [[ -f "${install_env}" ]]; then
    recorded=$(grep -m1 '^EXPERTISE_API_LOG_DIR=' "${install_env}" \
               | sed 's/^EXPERTISE_API_LOG_DIR=//' 2>/dev/null || true)
    if [[ -n "${recorded}" ]]; then
      printf '%s' "${recorded}"
      return 0
    fi
  fi

  # Layer 3: OS default (preserves behaviour for installs without the file)
  case "${OS}" in
    macos)          printf '%s' "${HOME}/Library/Logs/expertise-api" ;;
    linux)          printf '%s' "${XDG_STATE_HOME:-${HOME}/.local/state}/expertise-api" ;;
    wsl_to_windows) printf '%s' "${HOME}/.local/state/expertise-api" ;;
  esac
}

cmd_start() {
  case "${OS}" in
    linux)          systemctl --user start "${SERVICE}.service" ;;
    macos)          launchctl kickstart "gui/$(id -u)/${LABEL}" ;;
    wsl_to_windows) sc.exe start "${SERVICE}" ;;
  esac
}

cmd_stop() {
  case "${OS}" in
    linux)          systemctl --user stop "${SERVICE}.service" ;;
    macos)
      # Use `launchctl kill SIGTERM` rather than `launchctl bootout`.
      # bootout UNREGISTERS the service from the launchd domain, causing
      # `kickstart` in cmd_start to fail with "No such process" (#284).
      #
      # kill SIGTERM signals the running process while leaving the service
      # registered. ASP.NET Core handles SIGTERM gracefully and exits 0.
      # The plist's KeepAlive dict has SuccessfulExit=false, so launchd
      # does NOT respawn after a clean exit — the service stays stopped
      # until an explicit `kickstart`. The subsequent cmd_start `kickstart`
      # therefore works because the registration is still live.
      #
      # If the service is not currently running, kill returns a non-zero
      # exit, which we swallow (same || true behaviour as the old bootout).
      launchctl kill SIGTERM "gui/$(id -u)/${LABEL}" 2>/dev/null || true ;;
    wsl_to_windows) sc.exe stop "${SERVICE}" ;;
  esac
}

cmd_restart() {
  case "${OS}" in
    macos)
      # launchctl bootout is asynchronous: a cmd_stop+sleep+cmd_start sequence
      # races and surfaces "Service is already loaded" or duplicate-spawns.
      # `kickstart -k -p` is the atomic primitive (kill existing, then print
      # the new PID, which blocks until the supervised process is spawned).
      # See: man launchctl (Sonoma+).
      launchctl kickstart -k -p "gui/$(id -u)/${LABEL}" ;;
    linux)
      # `systemctl --user restart` is itself atomic and synchronous; no need
      # to compose stop+sleep+start.
      systemctl --user restart "${SERVICE}.service" ;;
    wsl_to_windows)
      # No atomic restart primitive exposed by sc.exe over the WSL interop
      # boundary; the stop+sleep+start pattern remains correct here.
      cmd_stop; sleep 1; cmd_start ;;
  esac
  wait_for_ready
}

wait_for_ready() {
  # Block until /health/ready returns 200 or READY_TIMEOUT elapses.
  # Skippable for stub-service tests where no HTTP listener is wired up.
  if [[ "${EXPERTISE_API_SKIP_READY:-0}" == "1" ]]; then
    log "ready: skipped (EXPERTISE_API_SKIP_READY=1)"
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    log "ready: WARNING — curl not found; readiness NOT verified (install curl, or set EXPERTISE_API_SKIP_READY=1 to silence)"
    return 0
  fi
  local deadline=$(( SECONDS + READY_TIMEOUT ))
  while (( SECONDS < deadline )); do
    if curl -fsS --max-time 2 "${READY_URL}" >/dev/null 2>&1; then
      log "ready: OK (${READY_URL})"
      return 0
    fi
    sleep 1
  done
  err "service did not reach ready state within ${READY_TIMEOUT}s at ${READY_URL}"
}

cmd_status() {
  case "${OS}" in
    linux)
      systemctl --user status --no-pager "${SERVICE}.service" || true ;;
    macos)
      if launchctl print "gui/$(id -u)/${LABEL}" 2>/dev/null \
          | awk '/^[[:space:]]*(state|pid|last exit code|program) =/ {print}'; then
        :
      else
        err "service not loaded — run scripts/install.sh"
      fi ;;
    wsl_to_windows)
      sc.exe query "${SERVICE}" ;;
  esac
}

cmd_logs() {
  local follow=0 lines=200
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow) follow=1; shift ;;
      -n|--lines)  lines="${2:?}"; shift 2 ;;
      *) err "unknown logs flag: $1" ;;
    esac
  done
  case "${OS}" in
    linux)
      if (( follow == 1 )); then
        journalctl --user -u "${SERVICE}.service" -n "${lines}" -f
      else
        journalctl --user -u "${SERVICE}.service" -n "${lines}" --no-pager
      fi ;;
    macos)
      local log_dir logfile
      log_dir="$(resolve_log_dir)"
      logfile="${log_dir}/stdout.log"
      [[ -f "${logfile}" ]] || err "no log file at ${logfile}"
      if (( follow == 1 )); then
        tail -n "${lines}" -f "${logfile}"
      else
        tail -n "${lines}" "${logfile}"
      fi ;;
    wsl_to_windows)
      powershell.exe -NoProfile -Command \
        "Get-WinEvent -ProviderName '${SERVICE}' -MaxEvents ${lines} | Format-List" ;;
  esac
}

cmd_health() {
  command -v curl >/dev/null 2>&1 || err "curl not found"
  if curl -fsS --max-time 5 "${HEALTH_URL}"; then
    printf '\n'
    log "health: OK"
  else
    err "health check failed against ${HEALTH_URL}"
  fi
}

# ===========================================================================
# Backup / restore orchestration (ADR-012).
#
# Division of labour: the ExpertiseApi `backup`/`restore` CLI verbs own
# NDJSON + Merkle + manifest; these subcommands own tar/gzip/age/cosign and
# key/dependency bootstrap. Trust posture: cosign LOCAL-KEYPAIR mode with
# --tlog-upload=false / --insecure-ignore-tlog=true — the deliberate,
# ADR-012-documented offline stance (no Rekor at DR time; the backup public
# key, not a Fulcio identity, is the trust root). Config values are read
# with grep+sed, never sourced (same posture as install.env above).
# ===========================================================================

BACKUP_CONFIG_DIR="${EXPERTISE_API_BACKUP_CONFIG:-${XDG_CONFIG_HOME:-${HOME}/.config}/expertise-api/backup}"
BACKUP_ENV_FILE="${BACKUP_CONFIG_DIR}/backup.env"
SECRETS_FILE_DEFAULT="${XDG_CONFIG_HOME:-${HOME}/.config}/expertise-api/secrets.env"

_backup_env_get() {
  # _backup_env_get KEY — plain key=value read, no shell execution.
  [[ -f "${BACKUP_ENV_FILE}" ]] || return 0
  grep -m1 "^$1=" "${BACKUP_ENV_FILE}" | sed "s/^$1=//" 2>/dev/null || true
}

_require_cosign_version() {
  # Same 2.2.0 floor and version-extraction shape as scripts/verify-release.sh
  # vr_require_cosign (kept inline: apictl is symlinked onto PATH, so relative
  # sourcing of the repo tree is not reliable here).
  local v lowest min='2.2.0'
  v=$(cosign version --json 2>/dev/null \
        | grep -oiE '"gitVersion"[[:space:]]*:[[:space:]]*"v?[0-9.]+"' \
        | head -1 | sed 's/.*"v\{0,1\}\([0-9.]\{1,\}\).*/\1/' || true)
  if [[ -z "${v}" ]]; then
    v=$(cosign version 2>&1 | grep -oE 'GitVersion:[[:space:]]*v?[0-9.]+' \
          | head -1 | sed 's/.*v\{0,1\}\([0-9.]\{1,\}\).*/\1/' || true)
  fi
  [[ -n "${v}" ]] || err "could not determine cosign version (need >= ${min})"
  lowest=$(printf '%s\n%s\n' "${min}" "${v}" | sort -V | head -1)
  [[ "${lowest}" == "${min}" ]] || err "cosign ${v} is older than required ${min}"
}

_sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  else
    shasum -a 256 "$1" | awk '{print $1}'
  fi
}

_backup_missing_deps() {
  local missing=""
  for tool in cosign age age-keygen jq tar gzip; do
    command -v "${tool}" >/dev/null 2>&1 || missing="${missing} ${tool}"
  done
  printf '%s' "${missing# }"
}

_resolve_bin_dir() {
  # Precedence: env override -> install.env prefix -> install.sh default.
  if [[ -n "${EXPERTISE_API_BIN_DIR:-}" ]]; then
    printf '%s' "${EXPERTISE_API_BIN_DIR}"
    return 0
  fi
  local xdg_config install_env prefix
  xdg_config="${XDG_CONFIG_HOME:-${HOME}/.config}"
  install_env="${xdg_config}/expertise-api/install.env"
  if [[ -f "${install_env}" ]]; then
    prefix=$(grep -m1 '^EXPERTISE_API_PREFIX=' "${install_env}" \
             | sed 's/^EXPERTISE_API_PREFIX=//' 2>/dev/null || true)
    if [[ -n "${prefix}" ]]; then
      printf '%s' "${prefix}/bin"
      return 0
    fi
  fi
  printf '%s' "${HOME}/.local/share/expertise-api/bin"
}

_run_api_verb() {
  # _run_api_verb VERB [ARGS...] — source secrets + mirror the launch
  # wrapper's env (same rationale as scripts/migrate.sh: the DI graph must
  # match the runtime graph, and the connection string only lives in
  # secrets.env), then invoke the installed binary.
  local bin_dir prefix secrets_file
  bin_dir="$(_resolve_bin_dir)"
  prefix="$(dirname "${bin_dir}")"
  secrets_file="${EXPERTISE_API_SECRETS_FILE:-${SECRETS_FILE_DEFAULT}}"

  if [[ -f "${secrets_file}" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "${secrets_file}"
    set +a
  else
    log "WARNING: no secrets file at ${secrets_file} — relying on environment"
  fi

  export ASPNETCORE_ENVIRONMENT="${ASPNETCORE_ENVIRONMENT:-Production}"
  export Onnx__ModelPath="${Onnx__ModelPath:-${prefix}/models/model.onnx}"
  export Onnx__VocabPath="${Onnx__VocabPath:-${prefix}/models/vocab.txt}"

  local conn="${ConnectionStrings__DefaultConnection:-}"
  [[ -n "${conn}" ]] || err "ConnectionStrings__DefaultConnection is not set — edit ${secrets_file} first"
  [[ "${conn}" != *CHANGE_ME* ]] || err "ConnectionStrings__DefaultConnection still contains CHANGE_ME — edit ${secrets_file} first"

  if [[ -x "${bin_dir}/ExpertiseApi" ]]; then
    "${bin_dir}/ExpertiseApi" "$@"
  elif [[ -f "${bin_dir}/ExpertiseApi.dll" ]]; then
    command -v dotnet >/dev/null 2>&1 || err "dotnet CLI not found (required for fdd layout at ${bin_dir})"
    dotnet "${bin_dir}/ExpertiseApi.dll" "$@"
  else
    err "no ExpertiseApi binary at ${bin_dir} — run scripts/install.sh first (or set EXPERTISE_API_BIN_DIR)"
  fi
}

_backup_preflight() {
  # Validates the whole backup surface with actionable errors. Every failure
  # points at backup-init, which fixes all of them.
  local missing
  missing="$(_backup_missing_deps)"
  [[ -z "${missing}" ]] || err "missing tools:${missing:+ }${missing} — run: expertise-apictl backup-init --install-deps"
  _require_cosign_version
  [[ -f "${BACKUP_ENV_FILE}" ]] || err "no backup config at ${BACKUP_ENV_FILE} — run: expertise-apictl backup-init"

  COSIGN_KEY_FILE="$(_backup_env_get COSIGN_KEY)"
  COSIGN_PUB_FILE="$(_backup_env_get COSIGN_PUB)"
  AGE_IDENTITY_FILE="$(_backup_env_get AGE_IDENTITY)"
  AGE_RECIPIENTS_FILE="$(_backup_env_get AGE_RECIPIENTS)"
  BACKUP_OUTPUT_DIR="$(_backup_env_get OUTPUT_DIR)"

  for pair in "COSIGN_KEY:${COSIGN_KEY_FILE}" "COSIGN_PUB:${COSIGN_PUB_FILE}" \
              "AGE_IDENTITY:${AGE_IDENTITY_FILE}" "AGE_RECIPIENTS:${AGE_RECIPIENTS_FILE}"; do
    local key="${pair%%:*}" val="${pair#*:}"
    [[ -n "${val}" ]] || err "${key} not set in ${BACKUP_ENV_FILE} — re-run: expertise-apictl backup-init"
    [[ -f "${val}" ]] || err "${key} points at missing file ${val} — re-run: expertise-apictl backup-init"
  done
}

cmd_backup_init() {
  local install_deps=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --install-deps) install_deps=1; shift ;;
      *) err "unknown backup-init flag: $1" ;;
    esac
  done

  local missing
  missing="$(_backup_missing_deps)"
  if [[ -n "${missing}" ]]; then
    if (( install_deps == 1 )); then
      case "${OS}" in
        macos)
          command -v brew >/dev/null 2>&1 || err "Homebrew required for --install-deps on macOS (https://brew.sh)"
          local brew_pkgs=""
          for tool in ${missing}; do
            case "${tool}" in
              age-keygen) [[ " ${brew_pkgs} " == *" age "* ]] || brew_pkgs="${brew_pkgs} age" ;;
              age)        [[ " ${brew_pkgs} " == *" age "* ]] || brew_pkgs="${brew_pkgs} age" ;;
              *)          brew_pkgs="${brew_pkgs} ${tool}" ;;
            esac
          done
          log "installing via brew:${brew_pkgs}"
          # shellcheck disable=SC2086
          brew install ${brew_pkgs} ;;
        linux|wsl_to_windows)
          command -v apt-get >/dev/null 2>&1 \
            || err "--install-deps supports apt-based distros (Debian/Ubuntu); install${missing} via your package manager and re-run"
          local apt_pkgs=""
          for tool in ${missing}; do
            case "${tool}" in
              cosign) : ;;             # not in Debian repos — handled below
              age-keygen) apt_pkgs="${apt_pkgs} age" ;;
              *) apt_pkgs="${apt_pkgs} ${tool}" ;;
            esac
          done
          if [[ -n "${apt_pkgs}" ]]; then
            log "installing via apt:${apt_pkgs}"
            # shellcheck disable=SC2086
            sudo apt-get install -y ${apt_pkgs}
          fi
          if ! command -v cosign >/dev/null 2>&1; then
            err "cosign is not packaged in Debian — install per https://docs.sigstore.dev/cosign/system_config/installation/ (pin the version and verify the checksum, ADR-011 discipline), then re-run backup-init"
          fi ;;
      esac
    else
      err "missing tools:${missing:+ }${missing} — re-run with --install-deps, or install them and re-run"
    fi
  fi
  _require_cosign_version

  mkdir -p "${BACKUP_CONFIG_DIR}"
  chmod 700 "${BACKUP_CONFIG_DIR}"

  local cosign_key="${BACKUP_CONFIG_DIR}/cosign.key"
  local cosign_pub="${BACKUP_CONFIG_DIR}/cosign.pub"
  local age_identity="${BACKUP_CONFIG_DIR}/age-identity.txt"
  local age_recipients="${BACKUP_CONFIG_DIR}/age-recipients.txt"

  if [[ -f "${cosign_key}" ]]; then
    log "cosign keypair present at ${cosign_key} (preserved — never regenerated silently)"
  else
    # Passwordless by design: `apictl backup` must run unattended (cron) and
    # `restore` must work mid-disaster with no interactive prompt. The key is
    # protected by 700/600 file permissions; rotate to a passworded key only
    # if you accept prompts on every sign/verify.
    log "generating cosign keypair (passwordless, chmod 600)"
    (cd "${BACKUP_CONFIG_DIR}" && COSIGN_PASSWORD="" cosign generate-key-pair >/dev/null 2>&1)
    [[ -f "${cosign_key}" && -f "${cosign_pub}" ]] || err "cosign generate-key-pair did not produce ${cosign_key}"
  fi
  chmod 600 "${cosign_key}"

  if [[ -f "${age_identity}" ]]; then
    log "age identity present at ${age_identity} (preserved)"
  else
    log "generating age identity (chmod 600)"
    age-keygen -o "${age_identity}" 2>/dev/null
  fi
  chmod 600 "${age_identity}"

  if [[ ! -f "${age_recipients}" ]]; then
    # Recipients file starts with this host's own public key; append a second
    # recipient (offline/escrow key) here so backups stay decryptable if this
    # host's identity is lost — see the runbook's key-discipline note.
    grep -m1 '^# public key: ' "${age_identity}" | sed 's/^# public key: //' > "${age_recipients}"
    [[ -s "${age_recipients}" ]] || err "could not extract public key from ${age_identity}"
  fi

  if [[ ! -f "${BACKUP_ENV_FILE}" ]]; then
    cat > "${BACKUP_ENV_FILE}" <<EOF
# backup.env — expertise-apictl backup configuration (ADR-012).
# Plain key=value; read with grep+sed, never sourced. chmod 600.
COSIGN_KEY=${cosign_key}
COSIGN_PUB=${cosign_pub}
AGE_IDENTITY=${age_identity}
AGE_RECIPIENTS=${age_recipients}
OUTPUT_DIR=${HOME}/expertise-backups
EOF
    chmod 600 "${BACKUP_ENV_FILE}"
    log "wrote ${BACKUP_ENV_FILE}"
  else
    log "backup.env present at ${BACKUP_ENV_FILE} (preserved)"
  fi

  _backup_preflight
  log "backup-init: OK — keys in ${BACKUP_CONFIG_DIR}, artifacts will land in $(_backup_env_get OUTPUT_DIR)"
  log "IMPORTANT: back up ${age_identity} (losing it means losing your backups) and consider adding a second recipient to ${age_recipients}"
}

cmd_backup() {
  local output_override="" instance_id
  instance_id="$(hostname -s 2>/dev/null || uname -n)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --output)      output_override="${2:?--output needs a directory}"; shift 2 ;;
      --instance-id) instance_id="${2:?--instance-id needs a value}"; shift 2 ;;
      *) err "unknown backup flag: $1" ;;
    esac
  done

  _backup_preflight
  local out_dir="${output_override:-${BACKUP_OUTPUT_DIR}}"
  mkdir -p "${out_dir}"

  local workdir ts artifact
  workdir="$(mktemp -d)"
  trap 'rm -rf "${workdir}"' EXIT
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  artifact="${out_dir}/expertise-backup-${instance_id}-${ts}.tar"

  log "exporting via ExpertiseApi backup verb"
  _run_api_verb backup --output "${workdir}/payload" --instance-id "${instance_id}" \
    || err "export verb failed — nothing was signed or written to ${out_dir}"

  log "compressing + encrypting payload"
  tar -czf "${workdir}/payload.tar.gz" -C "${workdir}/payload" entries.jsonl audit.jsonl
  age -e -R "${AGE_RECIPIENTS_FILE}" -o "${workdir}/payload.tar.gz.age" "${workdir}/payload.tar.gz"
  rm -f "${workdir}/payload.tar.gz" "${workdir}/payload/entries.jsonl" "${workdir}/payload/audit.jsonl"

  # Bind the encrypted payload to the manifest BEFORE signing, so the
  # signature covers the payload hash (ADR-012 manifest schema).
  local payload_sha
  payload_sha="$(_sha256_file "${workdir}/payload.tar.gz.age")"
  jq --arg sha "${payload_sha}" '. + {payloadSha256: $sha}' \
    "${workdir}/payload/manifest.json" > "${workdir}/manifest.json"

  log "signing manifest (cosign local keypair, no transparency log)"
  COSIGN_PASSWORD="" cosign sign-blob --yes --key "${COSIGN_KEY_FILE}" \
    --tlog-upload=false \
    --output-signature "${workdir}/manifest.json.sig" \
    "${workdir}/manifest.json" >/dev/null

  tar -cf "${artifact}" -C "${workdir}" payload.tar.gz.age manifest.json manifest.json.sig
  chmod 600 "${artifact}"
  log "backup: OK — ${artifact}"
}

cmd_restore() {
  local artifact="" force_draft=0 accept_unsigned=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force-draft)              force_draft=1; shift ;;
      --i-accept-unsigned-backup) accept_unsigned=1; shift ;;
      -*) err "unknown restore flag: $1" ;;
      *)  [[ -z "${artifact}" ]] || err "multiple artifacts given"; artifact="$1"; shift ;;
    esac
  done
  [[ -n "${artifact}" ]] || err "usage: expertise-apictl restore ARTIFACT.tar [--force-draft] [--i-accept-unsigned-backup]"
  [[ -f "${artifact}" ]] || err "artifact not found: ${artifact}"

  _backup_preflight

  local workdir
  workdir="$(mktemp -d)"
  trap 'rm -rf "${workdir}"' EXIT

  # Member allowlist before extraction (ADR-011 tar-hardening posture): the
  # outer tar must contain exactly the three expected members, no paths.
  local members
  members="$(tar -tf "${artifact}")"
  if [[ "$(printf '%s\n' "${members}" | sort)" != "$(printf 'manifest.json\nmanifest.json.sig\npayload.tar.gz.age' | sort)" ]]; then
    err "unexpected artifact contents: $(printf '%s' "${members}" | tr '\n' ' ') — refusing to extract"
  fi
  tar -xf "${artifact}" -C "${workdir}"

  if (( accept_unsigned == 1 )); then
    log "WARNING: --i-accept-unsigned-backup — SKIPPING signature verification (dev escape hatch, ADR-012)"
  else
    log "verifying manifest signature (fail closed)"
    # --insecure-ignore-tlog is the documented, deliberate offline posture for
    # local-keypair mode (ADR-012): backups never touch Rekor, so there is no
    # transparency-log entry to check. The trust root is COSIGN_PUB.
    cosign verify-blob --key "${COSIGN_PUB_FILE}" \
      --signature "${workdir}/manifest.json.sig" \
      --insecure-ignore-tlog=true \
      "${workdir}/manifest.json" >/dev/null 2>&1 \
      || err "manifest signature verification FAILED — refusing to restore (pass --i-accept-unsigned-backup only if you understand ADR-012's trust policy)"
  fi

  log "verifying payload hash against manifest"
  local declared actual
  declared="$(jq -r '.payloadSha256 // empty' "${workdir}/manifest.json")"
  [[ -n "${declared}" ]] || err "manifest carries no payloadSha256 — artifact was not produced by 'expertise-apictl backup'"
  actual="$(_sha256_file "${workdir}/payload.tar.gz.age")"
  [[ "${declared}" == "${actual}" ]] || err "payload hash mismatch (manifest ${declared}, actual ${actual}) — refusing to restore"

  log "decrypting payload"
  age -d -i "${AGE_IDENTITY_FILE}" -o "${workdir}/payload.tar.gz" "${workdir}/payload.tar.gz.age"
  mkdir -p "${workdir}/payload"
  tar -xzf "${workdir}/payload.tar.gz" -C "${workdir}/payload"
  cp "${workdir}/manifest.json" "${workdir}/payload/manifest.json"

  log "importing via ExpertiseApi restore verb"
  local verb_args=(restore --input "${workdir}/payload" --mode replace)
  (( force_draft == 0 )) || verb_args+=(--force-draft)
  _run_api_verb "${verb_args[@]}" || err "restore verb failed — see log output above"
  log "restore: OK"
}

case "${1:-}" in
  start)      shift; cmd_start "$@" ;;
  stop)       shift; cmd_stop "$@" ;;
  restart)    shift; cmd_restart "$@" ;;
  status)     shift; cmd_status "$@" ;;
  logs)       shift; cmd_logs "$@" ;;
  health)     shift; cmd_health "$@" ;;
  backup-init) shift; cmd_backup_init "$@" ;;
  backup)     shift; cmd_backup "$@" ;;
  restore)    shift; cmd_restore "$@" ;;
  ''|-h|--help) usage ;;
  *) err "unknown subcommand: $1 (try --help)" ;;
esac
