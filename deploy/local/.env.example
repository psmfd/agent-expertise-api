POSTGRES_DB=expertise
POSTGRES_USER=expertise
POSTGRES_PASSWORD=changeme

# API
AUTH__MODE=apikey
AUTH__APIKEY=dev-api-key-change-me
ConnectionStrings__DefaultConnection=Host=pgbouncer;Port=6432;Database=expertise;Username=expertise;Password=changeme;No Reset On Close=true
ConnectionStrings__MigrationConnection=Host=postgres;Port=5432;Database=expertise;Username=expertise;Password=changeme

# Aggregator up-sync (ADR-013) — spoke role only; leave disabled for a standalone
# instance. The hub credential must carry expertise.write.draft ONLY.
SYNC__ENABLED=false
SYNC__HUBURL=
SYNC__TOKENENDPOINT=
SYNC__CLIENTID=
SYNC__CLIENTSECRET=
