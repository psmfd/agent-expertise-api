{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Auth": {
    "Mode": "Hybrid",
    "ApiKey": "dev-api-key-change-me",
    "ApiKeyDefaults": {
      "DefaultTenant": "legacy",
      "DefaultPrincipal": "api-client"
    },
    "AgentUserAgents": {
      "Patterns": [
        "pi-coding-agent",
        "claude-code",
        "codex-cli",
        "curl/*"
      ]
    }
  }
}
